# ReQCollect — 配置示例
# 复制为 .env 后修改

APP_NAME=ReQCollect
APP_VERSION=0.1.0
DEBUG=False
HOST=0.0.0.0
PORT=9900

# LLM (DeepSeek 兼容 API)
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# PM Agent
SUFFICIENCY_THRESHOLD=0.75
DATA_DIR=./pm_data

# MySQL (留空则自动回退 JSON 文件)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=reqcollect
# MYSQL_PASSWORD=
# MYSQL_DATABASE=reqcollect
# MYSQL_REQUIRED=false
