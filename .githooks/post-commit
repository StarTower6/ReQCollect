#!/bin/bash
# post-commit hook — 每次提交完成后：
#   1. 自动推送到 GitHub
#   2. 推送成功后自动在本地部署更新（重启后端 + 构建前端）
# 安装: git config core.hooksPath .githooks (已配)
# 调试: .githooks/post-commit 直接运行看输出

REMOTE="origin"
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
PROJECT_DIR=$(git rev-parse --show-toplevel 2>/dev/null)

if [ -z "$BRANCH" ] || [ "$BRANCH" = "HEAD" ]; then
    exit 0
fi

cd "$PROJECT_DIR" || exit 1

echo ""
echo "============================================"
echo "  [deploy] post-commit: $BRANCH"
echo "============================================"

# ── 1. 推送 ──
echo "[deploy] Pushing to $REMOTE/$BRANCH..."
PUSH_OUTPUT=$(git push "$REMOTE" "$BRANCH" 2>&1)
PUSH_EXIT=$?
echo "$PUSH_OUTPUT"

if [ $PUSH_EXIT -ne 0 ]; then
    echo "[deploy] git push failed (code $PUSH_EXIT), continuing anyway..."
fi

echo "[deploy] ✅ Push done"

# ── 2. 本地部署（非 Docker，本地进程方式）──

# ── 2a. 先关旧进程 ──
echo "[deploy] Killing old processes..."

# 杀旧后端：用端口方式更可靠
PORT9900_PID=$(netstat -ano | grep ":9900 " | grep LISTENING | awk '{print $5}' | head -1 2>/dev/null)
if [ -n "$PORT9900_PID" ] && [ "$PORT9900_PID" != "0" ]; then
    taskkill //F //PID "$PORT9900_PID" 2>/dev/null
    echo "[deploy] Killed port 9900 (PID $PORT9900_PID)"
fi
# 同时也杀 uvicorn 进程名
for PID in $(tasklist //NH //FI "IMAGENAME eq python*" 2>/dev/null | grep -i uvicorn | awk '{print $2}' 2>/dev/null); do
    taskkill //F //PID "$PID" 2>/dev/null
done

# 杀旧前端(端口5173方式，比按进程名可靠)
PORT5173_PID=$(netstat -ano | grep ":5173 " | grep LISTENING | awk '{print $5}' | head -1 2>/dev/null)
if [ -n "$PORT5173_PID" ] && [ "$PORT5173_PID" != "0" ]; then
    taskkill //F //PID "$PORT5173_PID" 2>/dev/null
    echo "[deploy] Killed port 5173 (PID $PORT5173_PID)"
fi
sleep 2

# ── 2b. 构建前端 ──
echo "[deploy] Building frontend..."
cd "$PROJECT_DIR/reqcollect-web" || exit 1
npm run build > /tmp/frontend-build.log 2>&1
if [ $? -eq 0 ]; then
    echo "[deploy] ✅ Frontend build OK"
else
    echo "[deploy] ⚠️ Frontend build failed (see /tmp/frontend-build.log)"
fi

# ── 2c. 启动后端 ──
cd "$PROJECT_DIR" || exit 1
echo "[deploy] Starting backend..."
VENV="$PROJECT_DIR/.venv"
if [ -d "$VENV" ]; then
    source "$VENV/Scripts/activate"
    nohup uvicorn app.main:app --host 0.0.0.0 --port 9900 > /tmp/backend.log 2>&1 &
    BACKEND_PID=$!
    echo "[deploy] Backend started (PID $BACKEND_PID)"
else
    echo "[deploy] ⚠️ No .venv found, skipping backend start"
fi

# ── 2d. 等待健康检查 ──
echo "[deploy] Waiting for health check..."
for i in 1 2 3 4 5 6; do
    sleep 3
    STATUS=$(curl -s http://localhost:9900/api/health 2>/dev/null | python -c "import sys,json; d=json.load(sys.stdin); print(d.get('status',''))" 2>/dev/null)
    if [ "$STATUS" = "ok" ]; then
        echo "[deploy] ✅ Backend healthy (after ${i}x3s)"
        break
    fi
done

# ── 2e. 启动前端 dev server ──
echo "[deploy] Starting frontend dev server..."
cd "$PROJECT_DIR/reqcollect-web" || exit 1
nohup npx vite --port 5173 --strictPort > /tmp/frontend.log 2>&1 &
sleep 3
# 检查是否成功启动在 5173
if netstat -ano 2>/dev/null | grep ":5173 " | grep LISTENING >/dev/null; then
    echo "[deploy] ✅ Frontend ready at http://localhost:5173"
else
    # 如果 5173 仍被占用，看看 vite fallback 到哪个端口了
    ACTUAL_PORT=$(grep -oP 'http://localhost:\K\d+' /tmp/frontend.log 2>/dev/null | tail -1)
    echo "[deploy] ⚠️ Frontend started at http://localhost:${ACTUAL_PORT:-unknown}"
fi

echo ""
echo "============================================"
echo "  [deploy] ✅ Deployment complete"
echo "  Backend:  http://localhost:9900"
echo "  Frontend: http://localhost:5173"
echo "  API docs: http://localhost:9900/docs"
echo "============================================"
