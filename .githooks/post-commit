#!/bin/bash
# post-commit hook — 每次提交完成后：
#   1. 自动推送到 GitHub（静默）
#   2. 推送成功后自动用 Docker 部署到本地（静默）
# 安装: .git/hooks/post-commit + chmod +x

REMOTE="origin"
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

if [ -z "$BRANCH" ] || [ "$BRANCH" = "HEAD" ]; then
    exit 0
fi

# ── 1. 推送 ──
PUSH_OUTPUT=$(git push "$REMOTE" "$BRANCH" 2>&1)
PUSH_EXIT=$?

if [ $PUSH_EXIT -ne 0 ]; then
    # push 失败不阻塞后续流程，但记录
    echo "[deploy] git push failed (code $PUSH_EXIT), continuing..."
fi

# ── 2. Docker 部署 ──
# 检查 docker compose 是否可用
if ! command -v docker &>/dev/null; then
    echo "[deploy] docker not found, skipping deployment"
    exit 0
fi

# 检查 docker-compose.yml 是否存在
COMPOSE_FILE="docker-compose.yml"
if [ ! -f "$COMPOSE_FILE" ]; then
    echo "[deploy] $COMPOSE_FILE not found, skipping deployment"
    exit 0
fi

echo "[deploy] 🚀 Rebuilding and deploying..."

# 构建并启动（前台会有几秒输出，后台跑完）
# 只用 app 服务（不重启 mysql/nginx，避免影响运行中的服务）
docker compose --project-directory . build reqcollect 2>&1 | while IFS= read -r line; do
    echo "[deploy:build] $line"
done

# 重启应用容器
docker compose --project-directory . up -d reqcollect 2>&1 | while IFS= read -r line; do
    echo "[deploy:up] $line"
done

# 等待健康检查
echo "[deploy] ⏳ Waiting for health check..."
for i in $(seq 1 12); do
    sleep 5
    STATUS=$(curl -s http://localhost:9900/api/health 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null)
    if [ "$STATUS" = "ok" ]; then
        echo "[deploy] ✅ Deployment successful (ready after ${i}x5s)"
        exit 0
    fi
done

echo "[deploy] ⚠️ Health check did not pass within 60s, but containers are running"
